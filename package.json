{
  "name": "takiuddin-portfolio-hono",
  "version": "1.0.0",
  "type": "module",
  "main": "src/index.tsx",
  "dependencies": {
    "@cloudflare/kv-asset-handler": "^0.4.0",
    "@tailwindcss/cli": "^4.1.8",
    "hono": "^4.6.3",
    "tailwindcss": "^4.1.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241106.0",
    "@types/node": "^22.8.6",
    "sharp": "^0.33.0",
    "typescript": "^5.6.3",
    "wrangler": "^4.36.0"
  },
  "optionalDependencies": {
    "sharp": "^0.33.0"
  },
  "scripts": {
    "dev": "wrangler dev src/index.tsx",
    "build": "npm run build:css && wrangler deploy --dry-run",
    "build:css": "npx tailwindcss -i assets/css/input.css -o assets/css/output.css",
    "deploy": "npm run build:css && wrangler deploy",
    "deploy:preview": "npm run build:css && wrangler deploy --env preview",
    "optimize:images": "node scripts/optimize-images.js",
    "optimize:images:responsive": "node scripts/optimize-images.js --responsive"
  }
}
